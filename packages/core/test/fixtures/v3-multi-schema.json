{
  "article": {
    "kind": "collectionType",
    "collectionName": "articles",
    "info": { "name": "Article" },
    "attributes": {
      "title": { "type": "string", "required": true },
      "body": { "type": "richtext" },
      "author": { "model": "author", "via": "articles" },
      "categories": { "collection": "category", "via": "articles", "dominant": true }
    },
    "connection": "mongo"
  },
  "author": {
    "kind": "collectionType",
    "collectionName": "authors",
    "info": { "name": "Author" },
    "attributes": {
      "name": { "type": "string", "required": true },
      "email": { "type": "email" },
      "bio": { "type": "text" },
      "articles": { "collection": "article", "via": "author" },
      "avatar": { "model": "file", "via": "related", "plugin": "upload" }
    }
  },
  "category": {
    "kind": "collectionType",
    "collectionName": "categories",
    "info": { "name": "Category" },
    "attributes": {
      "name": { "type": "string", "required": true },
      "description": { "type": "text" },
      "articles": { "collection": "article", "via": "categories" }
    }
  }
}
